# Express backend
PORT=3001
SERVER_HOST=127.0.0.1
# Recommended primary store for visitor presence, admin sessions, and visitor logs.
# If Redis is unavailable, the backend falls back to per-process memory only.
REDIS_URL=redis://localhost:6379
ADMIN_PASSWORD=change-me
SESSION_SECRET=replace-with-a-long-random-secret
PRESENCE_TTL_SECONDS=60
ADMIN_SESSION_TTL_SECONDS=28800
# Server-side geo-IP lookup. Default uses ip-api.com with lang=zh-CN so the
# provider returns Chinese country/region/city values directly.
# Note: the free endpoint is HTTP-only; replace it with your paid HTTPS provider
# if you need production-grade encrypted lookups.
GEO_IP_LOOKUP_URL=http://ip-api.com/json/{ip}?fields=status,message,country,regionName,city&lang=zh-CN
GEO_IP_LOOKUP_TIMEOUT_MS=800
GEO_IP_CACHE_TTL_SECONDS=86400

# Frontend
# Leave blank for same-origin/reverse-proxy deployments. Set only if the API is hosted elsewhere.
VITE_VISITOR_API_BASE_URL=
